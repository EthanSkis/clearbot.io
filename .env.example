# Supabase (the existing shared project)
NEXT_PUBLIC_SUPABASE_URL=https://qunobrixpnerocdntkio.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_P-w2YUP5j2PcUPJrqZ3Xxg_Wk0BqSRu

# Server-only. Issue in Supabase dashboard → Project Settings → API.
# Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# URLs used for OAuth redirects + cross-subdomain links
SITE_URL=https://clearbot.io
COOKIE_DOMAIN=.clearbot.io

# Role-based access. Leave blank to rely solely on profiles.role in the DB.
TEAM_EMAIL_FALLBACK=ethan@clearbot.io

# Zoho SMTP — same credentials Supabase Auth is configured with.
# Port 465 uses implicit TLS; 587 uses STARTTLS.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=ethan@clearbot.io
SMTP_PASS=
MAIL_FROM=ClearBot <ethan@clearbot.io>

# Shared secret for Supabase Database Webhooks → /api/hooks/supabase.
# Generate with `openssl rand -hex 32` and paste into both Vercel env
# and each webhook's "X-Webhook-Secret" header in the Supabase dashboard.
SUPABASE_WEBHOOK_SECRET=
